{
  "name": "updater",
  "version": "1.0.0",
  "description": "FD Insights rate updater",
  "main": "src/updater.ts",
  "scripts": {
    "update": "tsx src/updater.ts",
    "update:hdfc": "tsx src/updater.ts --bank hdfc",
    "update:icici": "tsx src/updater.ts --bank icici",
    "update:sbi": "tsx src/updater.ts --bank sbi",
    "update:idb": "tsx src/updater.ts --bank idb",
    "test": "tsx --test src/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.40",
    "playwright": "^1.60.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  }
}
